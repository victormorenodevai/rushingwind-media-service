ELEVENLABS_API_KEY=your_key_here
HEYGEN_API_KEY=your_key_here
KIE_API_KEY=your_key_here
GDRIVE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Google Drive folders (IDs, not names)
# GDRIVE_MUSIC_LIBRARY_FOLDER_ID: carpeta donde se guardan las canciones de KIE.
#   Si está vacío, se genera canción nueva en cada video.
GDRIVE_MUSIC_LIBRARY_FOLDER_ID=

# Número máximo de canciones en la biblioteca.
# Cuando la biblioteca llega a este número, se reutiliza una canción aleatoria
# en lugar de generar una nueva — ahorra tokens y crea identidad de marca.
MUSIC_LIBRARY_SIZE=15

# URL pública del media-service en Railway (para que KIE notifique al terminar)
KIE_CALLBACK_URL=https://your-media-service.up.railway.app/music-callback
HEYGEN_POLL_TIMEOUT=1500
KIE_POLL_TIMEOUT=600
LOG_LEVEL=INFO

# Postgres — Railway lo inyecta automáticamente al agregar el plugin
# En local puedes usar: postgresql+asyncpg://user:pass@localhost:5432/media
DATABASE_URL=
