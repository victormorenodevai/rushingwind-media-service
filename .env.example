ELEVENLABS_API_KEY=your_key_here
HEYGEN_API_KEY=your_key_here
KIE_API_KEY=your_key_here

# URL pública de este servicio en Railway (para construir los download_url que devuelve la API)
# En Railway: Settings → Networking → Public URL
BASE_URL=https://your-media-service.up.railway.app

# Número máximo de canciones en la biblioteca local antes de reutilizar
MUSIC_LIBRARY_SIZE=15

# Directorios internos del contenedor
# Railway: 1 solo Volume montado en /app/data — ambos subdirectorios van dentro
MUSIC_DIR=/app/data/music
STORAGE_DIR=/app/data/storage

HEYGEN_POLL_TIMEOUT=1500
KIE_POLL_TIMEOUT=600
LOG_LEVEL=INFO

# Postgres — en Railway usar referencia: ${{Postgres.DATABASE_URL}}
# En local: postgresql+asyncpg://user:pass@localhost:5432/media
DATABASE_URL=
